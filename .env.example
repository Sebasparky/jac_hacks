# Option A: truly local Ollama
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b-instruct-q4_0
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=

# Option B: Moonshot hosted Kimi
# LLM_PROVIDER=kimi
# LLM_MODEL=kimi-k2.5
# LLM_BASE_URL=https://api.moonshot.ai/v1
# LLM_API_KEY=your-kimi-api-key

LLM_ALLOW_COMPILE=true
KIMI_THINKING=disabled
